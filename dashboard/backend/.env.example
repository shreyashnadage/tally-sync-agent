# TallyBridge Dashboard Backend Configuration

# Server
NODE_ENV=development
PORT=5000
HOST=0.0.0.0

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=tallybridge

# Optional: Full connection string alternative
# DATABASE_URL=postgresql://user:password@localhost:5432/tallybridge

# JWT (for future authentication)
JWT_SECRET=your-secret-key-change-in-production

# Logging
LOG_LEVEL=info
